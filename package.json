{
  "name": "orcaq",
  "productName": "orcaq",
  "description": "The open source | Next Generation database editor",
  "homepage": "https://orca-q.com/",
  "author": "Cinny",
  "license": "MIT",
  "version": "1.0.36",
  "main": "out/electron/main.js",
  "scripts": {
    "dev": "npm run nuxt:dev",
    "tauri:dev": "tauri dev",
    "tauri:build:runtime": "node scripts/tauri-before-build.mjs",
    "nuxt:dev": "nuxt dev",
    "nuxt:build": "NODE_OPTIONS=--max-old-space-size=8192 nuxt build",
    "nuxt:build-web": "nuxt build",
    "nuxt:generate": "nuxt generate",
    "app:build:tauri": "tauri build",
    "electron:dev": "concurrently -n nuxt,electron -c cyan,yellow \"nuxt dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development ELECTRON_DEV_SERVER_URL=http://localhost:3000 electron out/electron/main.js\"",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:build": "node scripts/electron-before-build.mjs && electron-builder",
    "electron:build:mac-m": "node scripts/electron-before-build.mjs && electron-builder --mac --arm64",
    "electron:pack": "node scripts/electron-before-build.mjs && electron-builder --dir",
    "npx:build": "npm run nuxt:build-web && node scripts/build-npx.mjs",
    "npx:pack": "cd npx-package && npm pack",
    "electrobun:dev": "cd electrobun-app && bun run dev",
    "electrobun:dev:watch": "cd electrobun-app && bun run dev:watch",
    "electrobun:build:canary": "cd electrobun-app && bun run build:canary",
    "electrobun:build:stable": "cd electrobun-app && bun run build:stable",
    "typecheck": "nuxt typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "format:husky": "prettier $(git diff --cached --name-only --diff-filter=ACMR | sed 's| |\\ |g') --write --ignore-unknown && git update-index --again",
    "version:patch": "npm version patch --no-git-tag-version && node scripts/sync-version.mjs",
    "version:minor": "npm version minor --no-git-tag-version && node scripts/sync-version.mjs",
    "version:major": "npm version major --no-git-tag-version && node scripts/sync-version.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "depcruise:json": "depcruise components core server pages layouts plugins --config .dependency-cruiser.js --output-type json > docs/dependency-graph.json",
    "test:all": "vitest --run",
    "test:unit": "vitest --run --project unit",
    "test:nuxt": "vitest --run --project nuxt",
    "test:e2e": "vitest --run --project e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:playwright": "playwright test"
  },
