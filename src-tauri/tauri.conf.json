{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "orcaq",
  "version": "1.0.37",
  "identifier": "com.cinny.orcaq",
  "build": {
    "beforeDevCommand": "node scripts/tauri-before-dev.mjs",
    "beforeBuildCommand": "node scripts/tauri-before-build.mjs",
    "devUrl": "http://localhost:3000",
    "frontendDist": "./placeholder-dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "orcaq",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "capabilities": [
        "desktop-capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/1024x1024.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/orcaq-runtime"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEMkM1MEIxMzcwMUM4ODYKUldTR3lBRTNzVkFzalk2Z1N3VDRXaklZeWt4RTdURWhIaUo1Q2VNblN2bVBzQXlOVldUd281S2IK",
      "endpoints": [
        "https://github.com/cin12211/orca-q/releases/latest/download/latest.json"
      ]
    }
  }
}
