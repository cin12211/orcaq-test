# Tauri updater signing
#
# Important:
# - Tauri build does NOT automatically read `.env` files for updater signing.
# - Copy this file to a local env file such as `.env.local`, then load it into
#   the same shell before running `bun run app:build:tauri`.
# - In this repo, the private key must match the public key in
#   `src-tauri/tauri.conf.json`. The current matching local key is
#   `~/.tauri/orcaq-updater.key`.
#
# Example:
#   cp .env.example .env.local
#   set -a; source .env.local; set +a
#   bun run app:build:tauri

# Recommended for local builds: provide the full private key content.
# Example:
#   export TAURI_SIGNING_PRIVATE_KEY="$(cat "$HOME/.tauri/orcaq-updater.key")"
TAURI_SIGNING_PRIVATE_KEY=""

# Optional if your private key is password protected.
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=""

# Alternative: some Tauri versions also accept a file path in
# `TAURI_SIGNING_PRIVATE_KEY`, but content is the safest option.
