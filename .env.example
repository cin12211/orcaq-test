# =============================================================================
# OrcaQ — Environment Variables
# Copy this file to .env and customize as needed
# =============================================================================

# --- OrcaQ Application ---
ORCAQ_PORT=9432

# SQLite file connections are enabled by default.
# Set false on hosted web deployments that should not expose server-side SQLite file access.
# NUXT_PUBLIC_SQLITE3_CONNECTIONS_ENABLED=false


# --- Analytics (optional) ---
# NUXT_AMPLITUDE_API_KEY=

# --- Public links (optional) ---
# NUXT_GG_FORM_LINK=
# NUXT_GITHUB_LINK=https://github.com/cin12211/orca-q

# --- Desktop App Download Banner ---
# Set true to show a banner encouraging users to download the desktop app (Mac/Linux)
# NUXT_PUBLIC_SHOW_DOWNLOAD_BANNER=false
# NUXT_PUBLIC_DOWNLOAD_LINK=https://orca-q.com/download
